{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Imagine",
  "version": "1.0.4",
  "identifier": "com.slaur.grok-imagine",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grok Imagine",
        "width": 1080,
        "height": 780,
        "minWidth": 220,
        "minHeight": 480,
        "decorations": false,
        "backgroundColor": "#080808",
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      },
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
